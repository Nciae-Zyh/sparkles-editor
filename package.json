{
  "name": "simple-editor",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=8192 nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:preview": "pnpm build && wrangler deploy --env preview"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.95",
    "@iconify-json/simple-icons": "^1.2.72",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/content": "^3.12.0",
    "@nuxt/hints": "1.0.0-alpha.5",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxthub/core": "^0.10.6",
    "@nuxtjs/device": "4.0.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@pinia/nuxt": "0.11.3",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-emoji": "^3.20.0",
    "@tiptap/extension-list": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/vue-3": "^3.20.0",
    "@vercel/blob": "^2.3.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "better-sqlite3": "^12.6.2",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.23",
    "marked": "^17.0.3",
    "nuxt": "^4.3.1",
    "nuxt-vue3-google-signin": "^0.0.13",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "prosemirror-tables": "^1.8.5",
    "scule": "^1.3.0",
    "shiki": "^3.23.0",
    "tailwindcss": "^4.2.1",
    "tiptap-extension-code-block-shiki": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^10.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.69.0"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "sqlite3",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  }
}
